    <style>
        /* ДИНАМІЧНІ ЗМІННІ ТЕМ */
        :root {
            --bg-body: #020617; 
            --bg-container: linear-gradient(180deg, #0f172a 0%, #020617 100%);
            --text-main: #f1f1f1;
            --text-header: #ffffff;
            --text-sub: #94a3b8;
            --card-bg: rgba(30, 41, 59, 0.4);
            --accent: rgb(222, 26, 161); /* Рожевий акцент */
            --active-glow: rgba(222, 26, 161, 0.6);
            --border-ui: rgba(255, 255, 255, 0.1);
            --nav-btn-bg: rgba(255, 255, 255, 0.05);
        }

        body.theme-light {
            --bg-body: #e2e8f0;
            --bg-container: linear-gradient(180deg, #f1f5f9 0%, #e2e8f0 100%);
            --text-main: #0f172a; 
            --text-header: #000000; 
            --text-sub: #475569;
            --card-bg: rgba(255, 255, 255, 0.95);
            --border-ui: rgba(0, 0, 0, 0.1);
            --active-glow: rgba(222, 26, 161, 0.3);
            --nav-btn-bg: rgba(0, 0, 0, 0.05);
        }

        body.theme-medium {
            --bg-body: #1e293b;
            --bg-container: linear-gradient(180deg, #334155 0%, #1e293b 100%);
            --text-main: #f8fafc;
            --text-header: #ffffff;
            --text-sub: #cbd5e1;
            --card-bg: rgba(15, 23, 42, 0.6);
            --border-ui: rgba(255, 255, 255, 0.05);
            --nav-btn-bg: rgba(255, 255, 255, 0.05);
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            margin: 0;
            display: flex;
            justify-content: center;
            min-height: 100vh;
            transition: all 0.4s ease;
            overflow-x: hidden;
        }

        .app-container {
            width: 100%;
            max-width: 550px;
            background: var(--bg-container);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            position: relative;
            box-shadow: 0 0 100px rgba(0,0,0,0.8);
            border-left: 1px solid var(--border-ui);
            border-right: 1px solid var(--border-ui);
            z-index: 2;
        }

        /* UI ЕЛЕМЕНТИ */
        .header {
            padding: 15px 20px;
            background: rgba(15, 23, 42, 0.1);
            border-bottom: 3px solid var(--accent);
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(25px);
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 95px;
        }

        .status-widget {
            background: rgba(0,0,0,0.1);
            padding: 8px 12px;
            border-radius: 12px;
            border: 1px solid var(--accent);
            max-width: 180px;
            cursor: pointer;
        }

        .date-nav {
            display: flex; 
            align-items: center; 
            justify-content: space-between;
            padding: 15px 20px; 
            background: rgba(0,0,0,0.05); 
            margin: 15px;
            border-radius: 20px; 
            border: 1px solid var(--border-ui);
        }

        .nav-arrow {
            width: 46px; height: 46px; 
            display: flex; align-items: center; justify-content: center;
            background: var(--card-bg); border-radius: 14px; 
            color: var(--accent); cursor: pointer; transition: 0.3s;
            border: 1px solid var(--border-ui);
        }
        .nav-arrow:hover { background: var(--accent); color: #000; }

        .pair-card {
            background: var(--card-bg); margin: 0 15px 15px; border-radius: 26px; padding: 25px;
            border: 1px solid var(--border-ui); transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
            position: relative; border-left-width: 12px;
            backdrop-filter: blur(10px);
        }

        .pair-card.is-current {
            background: var(--card-bg); 
            z-index: 10; 
            border: 4px solid var(--accent);
            border-left-width: 12px;
            transform: scale(1.025); 
            box-shadow: 0 0 50px var(--active-glow), inset 0 0 10px var(--active-glow);
        }

        .pair-card.is-upcoming { border: 2.5px dashed var(--accent); border-left-width: 12px; opacity: 0.85; }

        .subject-title {
            color: var(--text-header);
            font-size: 1.4rem;
            font-weight: 900;
            line-height: 1.2;
            margin-bottom: 0.8rem;
        }

        .status-tag {
            position: absolute; top: 15px; right: 15px; background: var(--accent); color: #000;
            font-size: 0.65rem; font-weight: 900; padding: 5px 14px; border-radius: 50px;
        }

        .progress-bar-inner { width: 100%; height: 8px; background: rgba(0,0,0,0.05); border-radius: 10px; margin-top: 15px; overflow: hidden; }
        .progress-fill { height: 100%; background: var(--accent); transition: width 0.5s ease; }
        .timer-text { display: flex; justify-content: space-between; font-size: 0.75rem; font-weight: 800; color: var(--accent); margin-top: 8px; }

        .join-group { display: flex; gap: 10px; margin-top: 20px; }
        .join-btn {
            flex: 1; background: var(--accent); color: #000 !important; display: block; text-align: center; padding: 16px;
            border-radius: 14px; font-weight: 900; font-size: 0.95rem; transition: 0.3s;
            text-decoration: none; text-transform: uppercase;
        }
        .copy-btn {
            width: 55px; background: var(--nav-btn-bg); border: 1px solid var(--border-ui);
            border-radius: 14px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.3s;
        }

        .lecturer-box { 
            background: rgba(0,0,0,0.05); padding: 15px; border-radius: 18px; 
            border: 1px solid var(--border-ui); margin-top: 15px; 
        }

        .access-info {
            font-family: 'Monaco', 'Consolas', monospace;
            font-size: 0.75rem;
            margin-top: 8px;
            font-weight: 700;
            background: rgba(0,0,0,0.1);
            padding: 5px 10px;
            border-radius: 8px;
            display: inline-block;
            color: var(--text-main);
        }

        .weekend-card {
            margin: 20px; padding: 80px 20px; text-align: center;
            background: var(--card-bg); border: 3px dashed var(--accent); border-radius: 40px;
            display: flex; flex-direction: column; align-items: center;
        }
        .weekend-title { font-size: 4rem; font-weight: 900; color: var(--accent); text-transform: uppercase; line-height: 1; }
        .weekend-btn { 
            background: var(--accent); color: #000; padding: 20px 50px; border-radius: 18px; 
            font-weight: 900; margin-top: 40px; text-transform: uppercase; cursor: pointer;
            box-shadow: 0 10px 30px var(--active-glow); transition: 0.3s;
        }

        /* SETTINGS MODAL */
        #settings-modal {
            position: fixed; inset: 0; background: rgba(0,0,0,0.95); backdrop-filter: blur(15px);
            z-index: 1000; display: none; align-items: center; justify-content: center; padding: 20px;
        }
        .modal-content {
            background: #1e293b; width: 100%; max-width: 500px; padding: 30px;
            border-radius: 35px; border: 2px solid var(--accent); max-height: 90vh; overflow-y: auto; color: white;
        }
        .setting-label { font-size: 0.75rem; font-weight: 800; color: var(--accent); text-transform: uppercase; margin: 20px 0 6px; display: block; }
        .option-btn { background: rgba(255,255,255,0.05); padding: 12px; border-radius: 12px; font-size: 0.7rem; font-weight: 700; text-align: center; cursor: pointer; border: 2px solid transparent; transition: 0.2s; }
        .option-btn.active { background: var(--accent); color: #000; border-color: white; }

        .sub-color-row {
            display: flex; align-items: center; justify-content: space-between;
            background: rgba(255,255,255,0.03); padding: 10px; border-radius: 12px; margin-bottom: 6px;
        }

        .jump-container { position: fixed; bottom: 30px; right: 20px; display: flex; align-items: center; gap: 10px; z-index: 150; }
        .back-jump-btn { background: var(--card-bg); color: var(--text-main); width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; border: 1px solid var(--border-ui); transition: 0.3s; }
        .quick-jump-btn { background: var(--accent); color: #000; padding: 20px 40px; border-radius: 45px; font-weight: 900; box-shadow: 0 10px 40px var(--active-glow); cursor: pointer; border: 4px solid rgba(255,255,255,0.3); text-transform: uppercase; }

        #bg-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; pointer-events: none; opacity: 0.3; }
        
        #alert-toast {
            position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 3000;
            background: white; color: black; padding: 15px 30px; border-radius: 20px;
            font-weight: 800; box-shadow: 0 20px 50px rgba(0,0,0,0.5); display: none;
        }
        
        .accent-text { color: var(--accent); }
    </style>
</head>
