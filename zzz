            const refDate = new Date(2026, 2, 23); 
            const diff = Math.floor((date - refDate) / (1000 * 60 * 60 * 24 * 7));
            return (Math.abs(diff) % 2 === 0) ? 'odd' : 'even';
        }

        function render() {
            const container = document.getElementById('schedule-container');
            const dateTitle = document.getElementById('display-date');
            const dayTitle = document.getElementById('display-day');
            const totalPairsEl = document.getElementById('total-pairs');
            if (!container || !dateTitle || !dayTitle || !totalPairsEl) return;

            const dayIdx = viewDate.getDay();
            const parity = getWeekParity(viewDate);
            const isToday = new Date().toDateString() === viewDate.toDateString();
            
            dateTitle.innerText = viewDate.toLocaleDateString('uk-UA', { day: 'numeric', month: 'long' });
            dayTitle.innerText = daysUa[dayIdx] + (dayIdx > 0 && dayIdx < 6 ? ` (${parity === 'odd' ? 'Непарний' : 'Парний'})` : "");

            container.innerHTML = '';
            const dayData = schedule[parity][dayIdx] || [];
            const now = new Date();
            const curM = now.getHours() * 60 + now.getMinutes();

            totalPairsEl.innerText = dayData.length > 0 ? `Всього пар: ${dayData.length}` : "";

            let activeIdx = dayData.findIndex(p => isToday && curM >= timeSlots[p.n-1].sM && curM <= timeSlots[p.n-1].eM);
            let upcomingIdx = isToday ? dayData.findIndex(p => curM < timeSlots[p.n-1].sM) : -1;

            if (isGlowTest && dayData.length > 0) activeIdx = 0;

            updateWidget(dayData, activeIdx, upcomingIdx, isToday);

            if (dayData.length === 0) {
                container.innerHTML = `<div class="weekend-card"><div class="text-7xl">🍹</div><div class="weekend-title">Вихідний</div><button class="weekend-btn" onclick="goToMonday()">До понеділка 📅</button></div>`;
            } else {
                dayData.forEach((pair, idx) => {
                    const slot = timeSlots[pair.n - 1];
                    const active = isGlowTest || (idx === activeIdx);
                    const next = !isGlowTest && (activeIdx === -1 && idx === upcomingIdx);
                    const savedColor = localStorage.getItem(`sub-color-${pair.id}`) || pair.color;

                    let extra = '';
                    if (active) {
                        const passed = isGlowTest ? 40 : (curM - slot.sM);
                        const total = (slot.eM - slot.sM);
                        const pct = Math.min(Math.max((passed / total) * 100, 0), 100);
                        extra = `<div class="progress-bar-inner"><div class="progress-fill" style="width: ${pct}%; background-color: ${savedColor}; box-shadow: 0 0 10px ${savedColor}"></div></div>
                                 <div class="timer-text" style="color: ${savedColor}"><span>Пройшло: ${passed} хв</span><span>Залишилось: ${total-passed} хв</span></div>`;
                    }

                    const card = document.createElement('div');
                    card.className = `pair-card ${active ? 'is-current' : ''} ${next ? 'is-upcoming' : ''}`;
                    card.style.borderLeftColor = savedColor;
                    if (active) {
                        card.id = 'target-card';
                        card.style.setProperty('--active-glow', savedColor.includes('rgb') ? savedColor.replace('rgb', 'rgba').replace(')', ', 0.6)') : savedColor + '99');
                    }

                    card.innerHTML = `
                        ${active ? `<span class="status-tag" style="background:${savedColor}">LIVE</span>` : ''}
                        ${next ? '<span class="status-tag">NEXT</span>' : ''}
                        <div class="text-[0.7rem] font-extrabold opacity-60 uppercase mb-1">Пара №${pair.n}</div>
                        <div class="text-sm font-bold opacity-60 mb-2">${slot.sT} — ${slot.eT}</div>
                        <div class="subject-title text-white">${pair.sub} ${pair.id.includes('sem') ? '<span class="text-xs opacity-50">(Семінар)</span>' : ''}</div>
                        ${extra}
                        <div class="lecturer-box">
                            <div class="text-xs font-black mb-1 text-white">${pair.name}</div>
                            ${pair.zoom ? `<div class="access-info">ID: ${pair.zoom} • Pass: ${pair.pass}</div>` : ''}
                        </div>
                        <div class="join-group">
                            <a href="${pair.link}" target="_blank" class="join-btn" style="background:${savedColor}">${pair.id === 'self_study' ? 'Матеріали' : 'Увійти'}</a>
                            <button class="copy-btn" onclick="copyToClipboard('${pair.link}')">
                                <svg width="22" height="22" fill="${savedColor}" viewBox="0 0 16 16"><path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1v-1z"/><path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5h3z"/></svg>
                            </button>
                        </div>
                    `;
                    container.appendChild(card);
                });
            }
        }

        function updateWidget(data, aIdx, uIdx, today) {
            const name = document.getElementById('widget-name');
            const label = document.getElementById('widget-label');
            if(!name || !label) return;
            if(isGlowTest) { label.innerText = "ТЕСТ:"; name.innerText = "Світіння предметів"; return; }
            if(!today) { label.innerText = "День:"; name.innerText = daysUa[viewDate.getDay()]; return; }
            if(aIdx !== -1) { label.innerText = "Зараз:"; name.innerText = data[aIdx].sub; } 
            else if(uIdx !== -1) { label.innerText = "Наступна:"; name.innerText = data[uIdx].sub; } 
            else { label.innerText = "Статус:"; name.innerText = "Пар немає"; }
        }

        function toggleGlowTest() {
            isGlowTest = true; render();
            setTimeout(() => { isGlowTest = false; render(); }, 8000);
        }

        function copyToClipboard(text) {
            const el = document.createElement('textarea');
            el.value = text; document.body.appendChild(el); el.select(); document.execCommand('copy'); document.body.removeChild(el);
            const t = document.getElementById('alert-toast'); t.style.display = 'block'; setTimeout(() => t.style.display = 'none', 2000);
        }

        function goToMonday() {
            const day = viewDate.getDay();
            let addDays = (day === 5) ? 3 : (day === 6 ? 2 : 1);
            viewDate.setDate(viewDate.getDate() + addDays); render();
        }

        function handleMasterJump() {
            viewDate = new Date(); render();
            setTimeout(() => { document.getElementById('target-card')?.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 100);
        }

        function handlePreviousJump() { viewDate.setDate(viewDate.getDate() - 1); render(); }
        function changeDate(dir) { viewDate.setDate(viewDate.getDate() + dir); render(); }
        
        function openSettings() { 
            genSubColorSettings(); 
            updateSettingsUI(); 
            document.getElementById('settings-modal').style.display = 'flex'; 
        }
        function closeSettings() { document.getElementById('settings-modal').style.display = 'none'; }
        
        function setAccent(color) { 
            config.theme = color; 
            document.documentElement.style.setProperty('--accent', color); 
            const glow = color.includes('rgb') ? color.replace('rgb', 'rgba').replace(')', ', 0.6)') : color + '80';
            document.documentElement.style.setProperty('--active-glow', glow); 
            localStorage.setItem('hub-theme', color); 
            render(); 
        }

        function setAppTheme(t) {
            appTheme = t; localStorage.setItem('hub-app-theme', t);
            document.body.className = (t === 'dark') ? 'theme-dark' : 'theme-' + t;
            updateSettingsUI(); render();
        }

        function setAnim(mode) { animMode = mode; localStorage.setItem('hub-anim', mode); updateSettingsUI(); initC(); }

        function genSubColorSettings() {
            const container = document.getElementById('sub-colors-config');
            if(!container) return;
            container.innerHTML = '';
            const uniqueSubs = {};
            // Об'єднуємо предмети для налаштувань кольору
            const allItems = [...Object.values(lecturers)];
            allItems.forEach(l => { if(!uniqueSubs[l.id]) uniqueSubs[l.id] = l; });
            
            Object.values(uniqueSubs).forEach(l => {
                const row = document.createElement('div');
                row.className = 'sub-color-row';
                const color = localStorage.getItem(`sub-color-${l.id}`) || l.color;
                row.innerHTML = `<span class="text-[0.7rem] font-bold truncate pr-2 text-white">${l.sub}</span><input type="color" value="${color}" oninput="localStorage.setItem('sub-color-${l.id}', this.value); render();" style="width:28px;height:28px;border:none;background:none;cursor:pointer;">`;
                container.appendChild(row);
            });
        }

        function updateSettingsUI() {
            document.querySelectorAll('.option-btn').forEach(b => b.classList.remove('active'));
            if(document.getElementById('anim-' + animMode)) document.getElementById('anim-' + animMode).classList.add('active');
            if(document.getElementById('theme-' + appTheme)) document.getElementById('theme-' + appTheme).classList.add('active');
        }

        function updateClock() { document.getElementById('live-clock').innerText = new Date().toLocaleTimeString('uk-UA'); }
        setInterval(updateClock, 1000);

        // --- CANVAS ENGINE ---
        const canvas = document.getElementById('bg-canvas');
        const ctx = canvas.getContext('2d');
        let pts = [];
        function initC() {
            canvas.width = window.innerWidth; canvas.height = window.innerHeight;
            pts = [];
            for (let i = 0; i < 90; i++) pts.push({ x: Math.random()*canvas.width, y: Math.random()*canvas.height, s: Math.random()*3+0.5, v: Math.random()*0.8+0.1 });
        }
        function animateC() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            if (animMode === 'off') return requestAnimationFrame(animateC);
            ctx.fillStyle = config.theme;
            pts.forEach((p, i) => {
                if (animMode === 'particles') { p.y -= p.v; if (p.y < 0) p.y = canvas.height; ctx.beginPath(); ctx.arc(p.x, p.y, p.s, 0, Math.PI * 2); ctx.fill(); } 
                else if (animMode === 'fire') { p.y -= p.v*3; p.x += Math.sin(Date.now()*0.005+i); if(p.y<-20){ p.y=canvas.height+20; p.x=Math.random()*canvas.width; } ctx.shadowBlur=15; ctx.shadowColor=config.theme; ctx.beginPath(); ctx.arc(p.x,p.y,Math.random()*3+1,0,Math.PI*2); ctx.fill(); ctx.shadowBlur=0; }
                else if (animMode === 'hearts') { p.y -= p.v; if (p.y < -40) p.y = canvas.height + 40; ctx.font = `${p.s * 15}px serif`; ctx.fillText('❤️', p.x, p.y); }
                else if (animMode === 'digital') { let lineH = Math.random()*50+20; p.y += p.v*10; if(p.y > canvas.height) p.y = -lineH; ctx.globalAlpha = 0.3; ctx.fillRect(p.x, p.y, 2, lineH); ctx.globalAlpha = 1; }
                else if (animMode === 'waves') { ctx.beginPath(); for(let x=0; x<canvas.width; x+=40){ let y = p.y + Math.sin(x*0.01 + Date.now()*0.002 + i)*30; ctx.lineTo(x, y); } ctx.globalAlpha = 0.2; ctx.stroke(); ctx.globalAlpha = 1; }
                else if (animMode === 'snow') { p.y += p.v*2; if(p.y > canvas.height) p.y = -10; ctx.beginPath(); ctx.arc(p.x, p.y, p.s, 0, Math.PI*2); ctx.fillStyle = 'white'; ctx.fill(); }
                else if (animMode === 'stars') { ctx.beginPath(); ctx.arc(p.x, p.y, p.s/2, 0, Math.PI*2); ctx.fill(); }
                else if (animMode === 'nexus') { ctx.beginPath(); ctx.arc(p.x, p.y, 1, 0, Math.PI*2); ctx.fill(); }
                else { ctx.beginPath(); ctx.arc(p.x, p.y, p.s, 0, Math.PI*2); ctx.fill(); }
            });
            requestAnimationFrame(animateC);
        }
        window.onresize = initC;
        window.onload = () => { 
            setAppTheme(appTheme); 
            setAccent(config.theme); 
            setAnim(animMode); 
            initC(); 
            animateC(); 
            render(); 
            updateClock(); 
        };
    </script>
</body>
